@page
@using AdvancedJobmatchingTool.Areas.Identity.Pages.Account
@model RegisterModel
@{
    ViewData["Title"] = "Registratie";
}

<style>
    h1 {
        text-align: center;
        margin-bottom: 1em;
    }

    .col-md-4 {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        margin-bottom: 0.5em;
    }

    .form-group {
        margin-bottom: 0.7em;
    }

    label.kandidaat-klant {
        margin-bottom: 0.7em;
        font-weight: bolder;
    }
</style>

<h1>@ViewData["Title"]</h1>


<div class="col-md-4">
    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" enctype="multipart/form-data">
        <h2>Maak een nieuw account aan.</h2>
        <hr />
        <div class="form-floating mb-3">
            <input asp-for="Input.Firstname" class="form-control" aria-required="true" placeholder="Firstname" />
            <label asp-for="Input.Firstname">Voornaam</label>
            <span asp-validation-for="Input.Firstname" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Lastname" class="form-control" aria-required="true" placeholder="Lastname" />
            <label asp-for="Input.Lastname">Familienaam</label>
            <span asp-validation-for="Input.Lastname" class="text-danger"></span>
        </div>
       
        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
            <label asp-for="Input.Email">E-mail</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.Password">Wachtwoord</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3">
            <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.ConfirmPassword">Bevestig wachtwoord</label>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
        </div>
        <div class="form-check">
            <input asp-for="Input.TermsCond" class="form-check-input" type="checkbox" />
            <label asp-for="Input.TermsCond" class="form-check-label">
                Ik ga akkoord met de <a href="/voorwaarden" target="_blank">algemene voorwaarden</a> en <a href="/privacy" target="_blank">privacyverklaring</a>.
            </label>
            <span asp-validation-for="Input.TermsCond" class="text-danger"></span>
        </div>
        <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Registreer</button>
    </form>
</div>


@section Scripts {
    <!--Is deze script nodig om uit te voeren ifv de rol?

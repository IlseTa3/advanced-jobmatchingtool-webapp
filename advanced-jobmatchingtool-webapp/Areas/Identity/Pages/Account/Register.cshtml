        document.getElementById("Input_Role").addEventListener("change", function() {
            var role = this.value;
            var section = document.getElementById("kandidaat-section");
            if (role === "Kandidaat") {
                section.style.display = "block";
            } else {
                section.style.display = "none";
            }
        });
    </script>
    -->
    <partial name="_ValidationScriptsPartial" />
}

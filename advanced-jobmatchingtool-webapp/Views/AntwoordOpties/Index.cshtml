 *@  
</table>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.11/css/jquery.dataTables.css" />

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.11/js/jquery.dataTables.js"></script>

    <script>
        $(function () {
            $('#custtable').DataTable({
                "ajax": {
                    //Client Side
                    "url": "/AntwoordOpties/GetAllAntwoordOptiesData",
                    "type": "GET",
                    "datatype": "json"
                },
                "columns": [
                    { "data": "id" },
                    { "data": "optieTekst" },
                    { "data": null, "defaultContent": "<a href='' class='del'>Verwijderen</a>" }
                ]

            });

            $('#custtable tbody').one('click', 'tr', function (e) {
                e.preventDefault();
                var id = $("td:first", this).text();
                if ($(e.target).is("a.del")) {
                    $.get('@Url.Action("Delete", "AntwoordOpties")', { id: id }, function (data) {
                        $("body").html(data);
                    });
                    return;
                }
                $.get('@Url.Action("Edit", "AntwoordOpties")', { id: id }, function (data) {
                    $("body").html(data);
                })
            });

        });
    </script>
}
<a asp-controller="HomeBeheer" asp-action="Index" class="btn btn-secondary">Terug</a>

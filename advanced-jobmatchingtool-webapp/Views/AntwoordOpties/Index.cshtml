@model IEnumerable<advanced_jobmatchingtool_webapp.ViewModels.AntwoordOpties.AntwoordOptieIndexViewModel>

@{
    ViewData["Title"] = "Index";
}

<style>
    #custtable tbody tr {
        cursor: pointer;
        color: darkred;
    }
</style>

<h1>Index</h1>

<p>
    <a asp-action="Create">Aanmaken</a>
</p>
<table id="custtable" class="display cell-border compact">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OptieTekst)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    </tbody>
    @*
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.OptieTekst)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>

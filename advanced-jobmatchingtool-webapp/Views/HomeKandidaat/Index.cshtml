@{
    ViewData["Title"] = "Overzicht Kandidaat";
}

<div class="container mt-4">

    <h2 class="text-primary mb-3">Overzicht voor kandidaten</h2>

    <div class="alert alert-info">
        <p class="mb-1">
            In dit overzicht vind je alle categorieën van vragen die je kan invullen.
        </p>
        <p class="mb-0">
            Je hoeft niet alles in één keer te doen. Je kan per categorie werken en op elk moment pauzeren.
        </p>
    </div>

    <h4 class="text-primary mt-4 mb-3">Vragenlijsten per categorie</h4>

    <div class="list-group mb-4">

        <a asp-controller="StudiesKandidaat" asp-action="Index"
           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span>Studies</span>
            <span class="badge bg-primary rounded-pill">Start</span>
        </a>

        <a asp-controller="WerkKandidaat" asp-action="Index"
           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span>Werkgerelateerde vragen</span>
            <span class="badge bg-primary rounded-pill">Start</span>
        </a>

        <a asp-controller="BehoeftesKandidaat" asp-action="Index"
           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span>Jouw behoeftes</span>
            <span class="badge bg-primary rounded-pill">Start</span>
        </a>

        <a asp-controller="TriggersKandidaat" asp-action="Index"
           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span>Jouw triggers</span>
            <span class="badge bg-primary rounded-pill">Start</span>
        </a>

        <a asp-controller="StressKandidaat" asp-action="Index"
           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <span>Stressgerelateerde vragen</span>
            <span class="badge bg-primary rounded-pill">Start</span>
        </a>

    </div>

    <h4 class="text-primary mt-4 mb-3">Persoonlijke gegevens</h4>

    <p class="mb-2">
        Wil je je persoonlijke gegevens aanpassen?
    </p>

    <a asp-controller="Kandidaat" asp-action="Profiel" class="btn btn-secondary">
        Persoonlijke gegevens aanpassen
    </a>

</div>

@model advanced_jobmatchingtool_webapp.Models.Prospect

@{
    ViewData["Title"] = "Contactformulier";
}
<style>
    h1 {
        text-align: center;
        margin-bottom: 1em;
    }

    .col-md-4 {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        margin-bottom: 0.5em;
    }

    .form-group {
        margin-bottom: 0.7em;
    }

    .form-check {
        margin-bottom: 1.5em;
        margin-top:1.5em;
    }

    .form-control {
        border: 2px solid black;
    }

    .control-label {
        font-size: 1.3em;
        margin-bottom:0.5em;
        font-weight:400;
    }


    
</style>
<h1 class="text-primary fw-bold">Contactformulier voor werkgevers</h1>


<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="NaamOnderneming" class="control-label"></label>
                <input asp-for="NaamOnderneming" class="form-control" />
                <span asp-validation-for="NaamOnderneming" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NaamContactpersoon" class="control-label"></label>
                <input asp-for="NaamContactpersoon" class="form-control" />
                <span asp-validation-for="NaamContactpersoon" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Btwnr" class="control-label"></label>
                <input asp-for="Btwnr" class="form-control" />
                <span asp-validation-for="Btwnr" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Adres" class="control-label"></label>
                <input asp-for="Adres" class="form-control" />
                <span asp-validation-for="Adres" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Postcode" class="control-label"></label>
                <input asp-for="Postcode" class="form-control" />
                <span asp-validation-for="Postcode" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Stad" class="control-label"></label>
                <input asp-for="Stad" class="form-control" />
                <span asp-validation-for="Stad" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Land" class="control-label"></label>
                <input asp-for="Land" class="form-control" />
                <span asp-validation-for="Land" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Telefoonnr" class="control-label"></label>
                <input asp-for="Telefoonnr" class="form-control" />
                <span asp-validation-for="Telefoonnr" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Gsmnr" class="control-label"></label>
                <input asp-for="Gsmnr" class="form-control" />
                <span asp-validation-for="Gsmnr" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OmschrijvingOnderneming" class="control-label"></label>
                <textarea asp-for="OmschrijvingOnderneming" class="form-control"></textarea>
                <span asp-validation-for="OmschrijvingOnderneming" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <input class="form-check-input" asp-for="TermsCond"/>
                <label class="form-check-label" asp-for="TermsCond">
                    Ik ga akkoord met de <a asp-controller="Home" asp-action="Privacy" target="_blank">
                        algemene voorwaarden
                    </a>.
                </label>
                <span asp-validation-for="TermsCond" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Verzenden" class="btn btn-primary btn-lg w-50 py-2" />
            </div>
        </form>
    </div>
</div>




@model advanced_jobmatchingtool_webapp.ViewModels.Antwoorden.AntwoordKandidaatIndexViewModel


@{
    ViewData["Title"] = "Index";
}

<h2 class="text-primary">Triggers Kandidaat:</h2>

<p>@Model.Voornaam @Model.Familienaam</p>

<p class="text-center text-danger">
    Geef in onderstaande stellingen aan in welke mate je dit lastig vindt. <br />
    1 is niet lastig - 5 is heel lastig.
</p>

@using (Html.BeginForm("SaveAntwoorden", "TriggersKandidaat", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div class="table-responsive">
        <table class="table table-bordered border-primary">
            <thead class="text-center">
                <tr>
                    <th>Vraag</th>
                    <th>Antwoord</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.VragenAntwoorden.Count; i++)
                {
                    <tr>
                        <td id="vraag">
                            @Model.VragenAntwoorden[i].VraagText
                            <input type="hidden" name="vragenAntwoorden[@i].VraagId" value="@Model.VragenAntwoorden[i].VraagId" />
                            <input type="hidden" name="vragenAntwoorden[@i].UserId" value="@Model.UserId" />
                            <input type="hidden" name="vragenAntwoorden[@i].Type" value="@Model.VragenAntwoorden[i].Type" />
                            @if (!string.IsNullOrEmpty(Model.VragenAntwoorden[i].ExtraInformatie))
                            {
                                <p><em>@Model.VragenAntwoorden[i].ExtraInformatie</em></p>
                            }
                        </td>
                        <td>
                            @if (Model.VragenAntwoorden[i].Type == "Radiobuttons")
                            {
                                foreach (var optie in Model.VragenAntwoorden[i].Opties)
                                {
                                    <label>
                                        <input type="radio" name="vragenAntwoorden[@i].Antwoord" value="@optie" @(Model.VragenAntwoorden[i].Antwoord == optie ? "checked" : "") /> @optie
                                    </label>
                                }
                            }
                            else if (Model.VragenAntwoorden[i].Type == "Checkboxen")
                            {
                                foreach (var optie in Model.VragenAntwoorden[i].Opties)
                                {
                                    <label>
                                        <input type="checkbox" name="vragenAntwoorden[@i].Antwoorden" value="@optie" @(Model.VragenAntwoorden[i].Antwoorden != null && Model.VragenAntwoorden[i].Antwoorden.Contains(optie) ? "checked" : "") /> @optie
                                    </label>
                                }
                            }
                            else
                            {
                                <input type="text" name="vragenAntwoorden[@i].Antwoord" class="form-control" value="@Model.VragenAntwoorden[i].Antwoord" />
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <button type="submit" class="btn btn-primary">Opslaan</button>
    <a asp-controller="HomeKandidaat" asp-action="Index" class="btn btn-secondary">Annuleren</a>
}

<h3>Ingevoerde Antwoorden</h3>
<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Vraag</th>
                <th>Antwoord</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var antwoord in Model.VragenAntwoorden)
            {
                <tr>
                    <td>@antwoord.VraagText</td>
                    <td>@antwoord.Antwoord</td>
                </tr>
            }
        </tbody>
    </table>
</div>



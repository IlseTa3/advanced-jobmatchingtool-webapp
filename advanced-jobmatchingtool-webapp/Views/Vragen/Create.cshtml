
@model advanced_jobmatchingtool_webapp.Models.Vraag

<h2>Nieuwe vraag</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Vraag</label>
        <input asp-for="VraagText" class="form-control" />
        <span asp-validation-for="VraagText" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Categorie</label>
        <input asp-for="Categorie" class="form-control" />
        <span asp-validation-for="Categorie" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Subcategorie</label>
        <input asp-for="SubCategorie" class="form-control" />
        <span asp-validation-for="SubCategorie" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Type</label>
        <input asp-for="Type" class="form-control" />
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Opties (Typ: Optie1, Optie2, Optie3, ...)</label>
        <input asp-for="Opties" class="form-control" />
        <span asp-validation-for="Opties" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Extra info</label>
        <input asp-for="ExtraInformatie" class="form-control" />
        <span asp-validation-for="ExtraInformatie" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label>Voor wie?</label>
        <input asp-for="VoorWie" class="form-control" />
        <span asp-validation-for="VoorWie" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Opslaan</button>
    <a asp-action="Index" class="btn btn-secondary">Annuleren</a>
</form>


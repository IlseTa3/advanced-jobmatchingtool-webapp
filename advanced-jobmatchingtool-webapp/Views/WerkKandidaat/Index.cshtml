@model advanced_jobmatchingtool_webapp.ViewModels.Antwoorden.AntwoordKandidaatIndexViewModel

@{
    ViewData["Title"] = "Vragenlijst";
}

<div class="container mt-4">

    <h2 class="text-primary mb-3">Werkgerelateerde vragen:</h2>

    <p class="fw-bold">@Model.Voornaam @Model.Familienaam</p>

    <div class="text-danger fw-bold alert-info text-center mb-4">
        Vul onderstaande vragen in. <br />
        Weet je niet wat je moet invullen? Je mag de vraag overslaan of, indien de optie er staat,
        antwoorden met <strong style="color:darkblue;">Ik weet het niet</strong>.
    </div>

    @using (Html.BeginForm("SaveAntwoorden", "WerkKandidaat", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <table class="table table-striped align-middle">
            <thead class="table-primary text-center">
                <tr>
                    <th style="white-space;nowrap;width: 60%;">Vraag</th>
                    <th style="width: 40%;">Antwoord</th>
                </tr>
            </thead>

            <tbody>
                @for (int i = 0; i < Model.VragenAntwoorden.Count; i++)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@Model.VragenAntwoorden[i].VraagText</div>

                            @if (!string.IsNullOrEmpty(Model.VragenAntwoorden[i].Categorie))
                            {
                                <div class="text-muted small">@Model.VragenAntwoorden[i].Categorie</div>
                            }

                            <input type="hidden" name="vragenAntwoorden[@i].VraagId" value="@Model.VragenAntwoorden[i].VraagId" />
                            <input type="hidden" name="vragenAntwoorden[@i].UserId" value="@Model.UserId" />
                            <input type="hidden" name="vragenAntwoorden[@i].Type" value="@Model.VragenAntwoorden[i].Type" />
                        </td>

                        <td class="text-center">

                            @if (Model.VragenAntwoorden[i].Type == "Radiobuttons")
                            {
                                <div class="d-flex justify-content-center gap-3">
                                    @foreach (var optie in Model.VragenAntwoorden[i].Opties)
                                    {
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio"
                                                   name="vragenAntwoorden[@i].Antwoord"
                                                   value="@optie"
                                                   @(Model.VragenAntwoorden[i].Antwoord == optie ? "checked" : "") />
                                            <label class="form-check-label">@optie</label>
                                        </div>
                                    }
                                </div>
                            }
                            else if (Model.VragenAntwoorden[i].Type == "Checkboxen")
                            {
                                <div class="d-flex flex-column align-items-start ms-4">
                                    @foreach (var optie in Model.VragenAntwoorden[i].Opties)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   name="vragenAntwoorden[@i].Antwoorden"
                                                   value="@optie"
                                                   @(Model.VragenAntwoorden[i].Antwoorden != null && Model.VragenAntwoorden[i].Antwoorden.Contains(optie) ? "checked" : "") />
                                            <label class="form-check-label">@optie</label>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <input type="text" class="form-control"
                                       name="vragenAntwoorden[@i].Antwoord"
                                       value="@Model.VragenAntwoorden[i].Antwoord" />
                            }

                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Opslaan</button>
            <a asp-controller="HomeKandidaat" asp-action="Index" class="btn btn-secondary">Annuleren</a>
        </div>
    }

    <hr class="my-4" />

    <h4 class="mb-3">Ingevoerde antwoorden</h4>

    <table class="table table-sm table-hover">
        <thead class="table-light">
            <tr>
                <th>Vraag</th>
                <th>Antwoord</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var antwoord in Model.VragenAntwoorden)
            {
                <tr>
                    <td>@antwoord.VraagText</td>
                    <td>@antwoord.Antwoord</td>
                </tr>
            }
        </tbody>
    </table>

</div>